# SynthAuth — Environment Secrets
# Copy this to .env and fill in real values before running in production.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────

# Fixed pepper included in every Argon2 hash.
# Use at least 32 random characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PEPPER=CHANGE-ME-use-a-long-random-string-here

# Cryptographic key for deterministic per-user salt generation (HMAC-SHA256).
# Must be a hex string of at least 32 hex chars (16 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNTH_SALT=CHANGE-ME-hex-encoded-32-bytes-minimum

# ── Optional ──────────────────────────────────────────────────────────────

# HTTP port for the test/web server (default: 3000)
# PORT=3000

# Session TTL in seconds (default: 3600 = 1 hour)
# SESSION_TTL=3600

# Path to SQLite database file (default: ./data/synth-auth.db)
# DB_PATH=./data/synth-auth.db
